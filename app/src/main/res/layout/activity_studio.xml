<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.StudioActivity">

    <!-- Camera Preview View -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Dark gradient overlay for lyrics legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/lyrics_top_shadow"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Lyrics ScrollView Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/svLyrics"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:layout_margin="24dp"
        android:background="@drawable/lyrics_bg"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvLyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="#80FFFFFF"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.3"
            android:text="Lyrics will appear here" />
    </androidx.core.widget.NestedScrollView>

    <!-- Record/Stop Overlay -->
    <FrameLayout
        android:id="@+id/recordStopOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Circular Record Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="42dp"
            android:backgroundTint="@color/primary"
            android:text="REC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:elevation="8dp"
            app:strokeColor="#50FF4081"
            app:strokeWidth="4dp"/>

        <!-- Circular Stop Button (Red, Glowing) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="42dp"
            android:backgroundTint="#D50000"
            android:text="STOP"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:visibility="gone"
            app:elevation="8dp"
            app:strokeColor="#50D50000"
            app:strokeWidth="6dp"/>
    </FrameLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchMic"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:checked="true"
        android:text="Mic"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/recordStopOverlay"
        app:layout_constraintEnd_toEndOf="@id/recordStopOverlay"
        app:layout_constraintStart_toStartOf="@id/recordStopOverlay" />

</androidx.constraintlayout.widget.ConstraintLayout>
